# Security configurations for production 2026
# Prevent execution of package scripts to avoid supply chain attacks
ignore-scripts=true

# Audit security
audit-level=moderate
fund=false

# Package integrity and verification
package-lock=true
package-lock-only=false
save-exact=true

# Registry security
registry=https://registry.npmjs.org/
strict-ssl=true

# Cache and performance
cache-max=86400000
prefer-offline=false

# Prevent automatic updates that could introduce vulnerabilities
save-prefix=""

# Engine strict mode
engine-strict=true

# Progress and logging
progress=false
loglevel=warn